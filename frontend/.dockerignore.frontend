# =============================================================================
# Frontend .dockerignore - Reduces build context significantly
# =============================================================================

# Dependencies (will be installed fresh)
node_modules/
.npm/
.yarn/
.pnp.*

# Build outputs
dist/
build/
.next/
out/

# Git
.git
.gitignore
.gitattributes

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Docker
Dockerfile*
docker-compose*
.docker/

# Documentation
docs/
*.md
README*
CHANGELOG*
LICENSE*

# Tests
tests/
__tests__/
*.test.js
*.test.ts
*.test.jsx
*.test.tsx
*.spec.js
*.spec.ts
coverage/
.nyc_output/
jest.config.*
cypress/
e2e/

# Environment
.env
.env.*
*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# CI/CD
.github/
.gitlab-ci.yml
jenkins/
Jenkinsfile
.circleci/

# Misc
*.bak
*.tmp
*.temp
.eslintcache
.stylelintcache
.cache/
