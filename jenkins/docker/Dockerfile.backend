# =============================================================================
# iMeetPro Backend - OPTIMIZED Multi-stage Dockerfile (FINAL)
# =============================================================================
# Build time: ~5-8 minutes
# Key optimizations:
#   - BuildKit cache mounts
#   - Better layer ordering
#   - Minimal runtime image
#   - Auto migrations on startup
# =============================================================================
# syntax=docker/dockerfile:1.4
# -----------------------------------------------------------------------------
# Stage 1: Dependencies Builder
# -----------------------------------------------------------------------------
FROM python:3.11-slim AS deps

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=0 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    libffi-dev \
    libssl-dev \
    default-libmysqlclient-dev \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

# Copy ONLY requirements first (better cache utilization)
COPY requirements.txt .

# Install Python dependencies with cache mount
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.txt

# -----------------------------------------------------------------------------
# Stage 2: Production Runtime
# -----------------------------------------------------------------------------
FROM python:3.11-slim AS production

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    APP_HOME=/app \
    PYTHONPATH=/app \
    DJANGO_SETTINGS_MODULE=SampleDB.settings

WORKDIR $APP_HOME

# Install ONLY runtime dependencies (minimal)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    default-mysql-client \
    libmariadb3 \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender1 \
    libgomp1 \
    curl \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create non-root user
RUN groupadd -r appgroup && useradd -r -g appgroup appuser

# Copy Python packages from deps stage
COPY --from=deps /usr/local/lib/python3.11/site-packages /usr/local/lib/python3.11/site-packages
COPY --from=deps /usr/local/bin /usr/local/bin

# Copy application code
COPY --chown=appuser:appgroup . .

# Create directories and log files
RUN mkdir -p /app/staticfiles /app/mediafiles /app/logs && \
    touch /app/attendance_verification.log \
          /app/django.log \
          /app/celery.log \
          /app/meetings_debug.log \
          /app/recurring_meetings.log \
          /app/notifications_debug.log \
          /app/participants_debug.log \
          /app/recording_service_debug.log && \
    chown -R appuser:appgroup /app

# Clean unnecessary files
RUN rm -rf *.sql *.pem *.key *.crt .env .vscode .git __pycache__ tests/ docs/ *.md chromedriver* || true

# =============================================================================
# Create entrypoint script with auto-migrations
# =============================================================================
RUN echo '#!/bin/bash\n\
set -e\n\
\n\
echo "🚀 Starting iMeetPro Backend..."\n\
\n\
# Run database migrations (only if DB is available)\n\
echo "📦 Running database migrations..."\n\
python manage.py migrate --noinput 2>/dev/null || echo "⚠️ Migration skipped (DB not ready or no changes)"\n\
\n\
# Start the main process\n\
echo "✅ Starting Gunicorn server..."\n\
exec "$@"' > /app/entrypoint.sh && chmod +x /app/entrypoint.sh

USER appuser

# Collect static files
RUN python manage.py collectstatic --noinput 2>/dev/null || true

EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Entrypoint runs migrations, then CMD starts gunicorn
ENTRYPOINT ["/app/entrypoint.sh"]
CMD ["gunicorn", "--bind", "0.0.0.0:8000", "--workers", "2", "--threads", "2", "--timeout", "120", "SampleDB.wsgi:application"]
